<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Contenedor Principal: Organiza la pantalla de login en una columna centralizada -->
<VBox alignment="CENTER" prefHeight="750.0" prefWidth="1300.0" spacing="30.0" style="-fx-background-color: #0b295c;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sentinel_agent.controller.InicioSesionController">
   <children>
      
      <!-- Sección del Logo: Muestra la identidad visual de la aplicación en la parte superior -->
      <ImageView fitHeight="250.0" fitWidth="350.0" preserveRatio="true">
         <image>
            <Image url="@img/logoSinFondo.png" />
         </image>
      </ImageView>

      <!-- Formulario de Acceso: Panel con fondo contrastado que contiene los campos de entrada -->
      <VBox alignment="CENTER" maxWidth="400.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #a6a6a6; -fx-background-radius: 10; -fx-border-color: #404040; -fx-border-radius: 10; -fx-border-width: 1;">
         <children>
            <!-- Entrada de Usuario: Identificador único del agente -->
            <TextField fx:id="txtUsuario" maxWidth="300.0" prefHeight="40.0" promptText="Nombre Usuario" style="-fx-background-color: white; -fx-padding: 10; -fx-font-size: 14px; -fx-alignment: center; -fx-text-fill: black;" />
            
            <!-- Entrada de Contraseña: Campo seguro para la clave de acceso -->
            <PasswordField fx:id="txtPassword" maxWidth="300.0" prefHeight="40.0" promptText="Contraseña" style="-fx-background-color: white; -fx-padding: 10; -fx-font-size: 14px; -fx-alignment: center; -fx-text-fill: black;" />
            
            <!-- Botón de Acción: Inicia el proceso de validación y conexión -->
            <Button mnemonicParsing="false" onAction="#handleLogin" prefWidth="180.0" style="-fx-background-color: #0b295c; -fx-text-fill: white; -fx-border-color: #000000; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 10 20; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Conectarse" />
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <effect>
            <!-- Efecto de profundidad para resaltar el formulario sobre el fondo -->
            <DropShadow color="#00000080" height="15.0" radius="7.0" width="15.0" />
         </effect>
      </VBox>

      <!-- Enlaces de Navegación: Opciones secundarias para registro y recuperación -->
      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <!-- Opción para nuevos usuarios -->
            <Hyperlink onAction="#irRegistro" text="¿No tienes usuario? Regístrate aquí" textFill="WHITE" underline="true" />
            
            <!-- Opción de recuperación de seguridad -->
            <Hyperlink onAction="#olvidePassword" text="¿Has olvidado tu contraseña?" textFill="#cccccc" underline="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Hyperlink>
         </children>
      </VBox>

   </children>
   <padding>
      <Insets bottom="70.0" left="40.0" right="60.0" top="40.0" />
   </padding>
</VBox>





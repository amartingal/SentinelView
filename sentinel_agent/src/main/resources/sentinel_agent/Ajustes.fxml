<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="750.0" prefWidth="1300.0" style="-fx-background-color: #0b295c;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sentinel_agent.controller.AjustesController">
   <padding>
      <Insets bottom="30.0" right="20.0" />
   </padding>
   <children>
      <!-- Contenido Central: Alineado exactamente como en InicioSesion -->
      <VBox alignment="CENTER" spacing="30.0">
         <children>
            <ImageView fitHeight="250.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@img/logoSinFondo.png" />
               </image>
            </ImageView>
            <VBox alignment="CENTER" maxWidth="450.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: #a6a6a6; -fx-background-radius: 10; -fx-border-color: #404040; -fx-border-radius: 10; -fx-border-width: 1;">
               <children>
                  <Button fx:id="btnDescargarInstalador" mnemonicParsing="false" onAction="#descargarInstalador" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-radius: 15; -fx-cursor: hand;" text="Descargar instalador&#10;del agente" textAlignment="CENTER">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnModificadorAgente" mnemonicParsing="false" onAction="#modificarAgente" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-radius: 15; -fx-cursor: hand;" text="Modificar agente de&#10;monitorización" textAlignment="CENTER">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnCambiarPass" mnemonicParsing="false" onAction="#cambiarPassword" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-radius: 15; -fx-cursor: hand;" text="Cambiar&#10;contraseña" textAlignment="CENTER">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnCerrarSesion" mnemonicParsing="false" onAction="#cerrarSesion" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-radius: 15; -fx-cursor: hand;" text="Cerrar Sesion">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnBorrarCuenta" mnemonicParsing="false" onAction="#borrarCuenta" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: black; -fx-border-radius: 15; -fx-cursor: hand;" text="Borrar Cuenta">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="25.0" left="40.0" right="40.0" top="25.0" />
               </padding>
               <effect>
                  <DropShadow color="#00000080" height="15.0" radius="7.0" width="15.0" />
               </effect>
            </VBox>
         </children>
      </VBox>

      <!-- Botón Volver: "Flotando" arriba a la izquierda para no desplazar el centro -->
      <HBox alignment="TOP_LEFT" pickOnBounds="false">
         <children>
            <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#volverAtras" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: black; -fx-border-radius: 10; -fx-cursor: hand;" text="Atras">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <HBox.margin>
                  <Insets left="30.0" top="20.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </children>
</StackPane>

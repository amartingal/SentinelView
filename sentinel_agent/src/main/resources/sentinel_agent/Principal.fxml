<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Estructura Principal: Utiliza un BorderPane para dividir la pantalla en áreas funcionales -->
<BorderPane maxHeight="750.0" maxWidth="1300.0" minHeight="740.0" minWidth="1300.0" prefHeight="750.0" prefWidth="1300.0" style="-fx-background-color: #0b295c;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sentinel_agent.controller.PrincipalController">
   
    <!-- BARRA LATERAL IZQUIERDA: Contiene los filtros y las opciones de gestión de usuario -->
    <left>
       <VBox alignment="TOP_CENTER" prefWidth="280.0" spacing="20.0" style="-fx-background-color: #a6a6a6; -fx-border-color: #404040; -fx-border-width: 0 2 0 0;" BorderPane.alignment="CENTER">
          <children>
             
             <!-- Filtro por Calendario -->
             <VBox alignment="CENTER" spacing="8.0">
                <children>
                   <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Seleccionar fecha:">
                      <font>
                         <Font size="14.0" />
                      </font>
                   </Label>
                   <DatePicker fx:id="datePicker" prefHeight="35.0" prefWidth="240.0" />
                </children>
                <VBox.margin>
                   <Insets top="20.0" />
                </VBox.margin>
             </VBox>
             
             <!-- Selector de Identidad de Usuario -->
             <VBox alignment="CENTER" spacing="8.0">
                <children>
                   <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Nombre Usuario:">
                      <font>
                         <Font size="14.0" />
                      </font>
                   </Label>
                   <ComboBox fx:id="comboIdUsuario" prefHeight="35.0" prefWidth="240.0" promptText="Seleccionar ID" style="-fx-background-color: white;" />
                </children>
             </VBox>
             
             <!-- Historial de Fechas Recientes: se rellena dinámicamente desde MongoDB en PrincipalController -->
             <VBox fx:id="vboxFechas" alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <VBox.margin>
                   <Insets top="20.0" />
                </VBox.margin>
             </VBox>
             


             <Button fx:id="btnAjustes" mnemonicParsing="false" onAction="#abrirAjustes" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #0b295c; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Ajustes">
                <VBox.margin>
                   <Insets bottom="20.0" top="20.0" />
                </VBox.margin>
             </Button>
          </children>
          <padding>
             <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
          </padding>
       </VBox>
    </left>
    
    <!-- ZONA CENTRAL: Visualización de los datos y reportes generados -->
    <center>
       <StackPane style="-fx-background-color: #b3b3b3;" BorderPane.alignment="CENTER">
          <padding>
             <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
          </padding>
          <children>
             
             <!-- Marca de Agua: Imagen de fondo con opacidad reducida -->
             <ImageView fitHeight="545.0" fitWidth="746.0" opacity="0.2" preserveRatio="true">
                <image>
                   <Image url="@img/logoSinFondo.png" />
                </image>
             </ImageView>
             
             <!-- Contenido Dinámico: Estadísticas + Lista de reportes + botón de exportación -->
             <VBox alignment="CENTER" maxWidth="900.0" prefWidth="900.0" spacing="20.0">
                <children>

                   <!-- ===== FRANJA DE ESTADÍSTICAS DEL DÍA ===== -->
                   <HBox alignment="CENTER" maxWidth="850.0" prefWidth="850.0" spacing="12.0" style="-fx-background-color: #0b295c; -fx-background-radius: 10; -fx-padding: 14 20 14 20;">
                      <VBox.margin>
                         <Insets left="20.0" right="20.0" top="18.0" />
                      </VBox.margin>
                      <children>
                         <!-- Tarjeta 1: Incidencias totales del día -->
                         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #132f5c; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-min-width: 115;">
                            <children>
                               <Label fx:id="lblTotalIncidencias" alignment="CENTER" prefHeight="40.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="0">
                                  <font>
                                     <Font name="System Bold" size="24.0" />
                                  </font>
                               </Label>
                               <Label style="-fx-text-fill: white; -fx-font-size: 10; -fx-wrap-text: true; -fx-text-alignment: center;" text="Incidencias hoy" />
                            </children>
                         </VBox>

                         <!-- Tarjeta 2: Puerto más repetido -->
                         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #132f5c; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-min-width: 115;">
                            <children>
                               <Label fx:id="lblPuertoTop" alignment="CENTER" prefHeight="40.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="-">
                                  <font>
                                     <Font name="System Bold" size="24.0" />
                                  </font>
                               </Label>
                               <Label style="-fx-text-fill: white; -fx-font-size: 10; -fx-wrap-text: true; -fx-text-alignment: center;" text="Puerto más frecuente" />
                            </children>
                         </VBox>

                         <!-- Tarjeta 3: Proceso más repetido -->
                         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #132f5c; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-min-width: 280;">
                            <children>
                               <Label fx:id="lblProcesoTop" alignment="CENTER" minHeight="40.0" prefWidth="250.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="-" wrapText="true">
                                  <font>
                                     <Font name="System Bold" size="18.0" />
                                  </font>
                               </Label>
                               <Label style="-fx-text-fill: white; -fx-font-size: 10; -fx-wrap-text: true; -fx-text-alignment: center;" text="Proceso más frecuente" />
                            </children>
                         </VBox>

                         <!-- Tarjeta 4: Equipos analizados -->
                         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #132f5c; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-min-width: 115;">
                            <children>
                               <Label fx:id="lblEquipos" alignment="CENTER" prefHeight="40.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="0">
                                  <font>
                                     <Font name="System Bold" size="24.0" />
                                  </font>
                               </Label>
                               <Label style="-fx-text-fill: white; -fx-font-size: 10; -fx-wrap-text: true; -fx-text-alignment: center;" text="Equipos analizados" />
                            </children>
                         </VBox>

                         <!-- Tarjeta 5: Reportes con estado crítico -->
                         <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #132f5c; -fx-background-radius: 8; -fx-padding: 12 16 12 16; -fx-min-width: 115;">
                            <children>
                               <Label fx:id="lblAlertas" alignment="CENTER" prefHeight="40.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="0">
                                  <font>
                                     <Font name="System Bold" size="24.0" />
                                  </font>
                               </Label>
                               <Label style="-fx-text-fill: white; -fx-font-size: 10; -fx-wrap-text: true; -fx-text-alignment: center;" text="Estado: ALERTA" />
                            </children>
                         </VBox>


                      </children>
                   </HBox>

                   <!-- Visualizador de Listado: Muestra los reportes centrados -->
                   <ListView fx:id="listaReportes" maxWidth="800.0" prefWidth="800.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                      <VBox.margin>
                         <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
                      </VBox.margin>
                   </ListView>
                   
                   <!-- Botón de Exportación: Permite descargar la información actual -->
                   <Button fx:id="btnExportar" maxHeight="50.0" maxWidth="350.0" minHeight="50.0" minWidth="350.0" mnemonicParsing="false" onAction="#exportarTodo" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #0b295c; -fx-text-fill: white; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Exportar todo">
                      <VBox.margin>
                         <Insets bottom="30.0" />
                      </VBox.margin>
                   </Button>
                </children>
             </VBox>
          </children>
       </StackPane>
    </center>
    
    <!-- El margen derecho ahora se gestiona con el padding del BorderPane -->

    <padding>
       <Insets bottom="45.0" left="15.0" right="35.0" top="15.0" />
    </padding>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Arc?>

<!-- Pantalla de Bienvenida (Splash Screen): Primera interfaz visible al arrancar la aplicación -->
<VBox alignment="CENTER" spacing="40" style="-fx-background-color: #0b295c;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sentinel_agent.controller.SplashScreenController">
    
    <!-- Sección de Identidad: Muestra el logo principal de la aplicación -->
    <StackPane prefHeight="200">
        <ImageView fx:id="logoView" fitWidth="300" preserveRatio="true">
            <!-- Imagen cargada desde la carpeta de recursos de imágenes -->
            <Image url="@img/logoSinFondo.png" /> 
        </ImageView>
    </StackPane>
    
    <!-- Indicador de Progreso: Arco circular que rotará mediante el controlador para simular carga -->
    <StackPane>
        <Arc fx:id="spinner" fill="TRANSPARENT" length="270.0" radiusX="30.0" radiusY="30.0" startAngle="90.0" stroke="#42d4f5" strokeWidth="10.0" />
    </StackPane>
    
    <!-- Feedback de Usuario: Texto informativo sobre el estado del arranque -->
    <Label fx:id="statusLabel" style="-fx-text-fill: white; -fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 14px;" text="Configurando el sistema..." />
</VBox>




